# DTL-Global Platform — Local Development Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# HubSpot — Developer platform 2025.2 static access token (hubspot/dtl-global-platform-app/ → hs project upload → install → app Auth tab).
# See docs/AUTHENTICATION.md. Token format is not limited to pat-...
HUBSPOT_ACCESS_TOKEN=your_hubspot_static_access_token_here

# Stripe (use test keys for development)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id_here

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# GitHub Personal Access Token (repo scope — for pipeline-factory integration)
# Required by scripts/deploy_client_website.py to add client sites
# to the pipeline-factory repo via GitHub API
GITHUB_TOKEN=ghp_your_github_token_here

# AWS (usually handled by AWS CLI profile, but can override)
# AWS_PROFILE=dtl-global
# AWS_REGION=us-east-1

# GitHub CodeStar Connection (for reference — actual ARN in SSM, not in .env for Lambda)
# SSM: /dtl-global-platform/github/codestar_connection_arn
# CODESTAR_CONNECTION_ARN=arn:aws:codestar-connections:us-east-1:ACCOUNT:connection/ID

# AWS SSM Parameter Store paths (Lambda / production — see docs/AUTHENTICATION.md and DTL_MASTER_PLAN.md Appendix C)
# HUBSPOT_TOKEN_PARAM=/dtl-global-platform/hubspot/token
# STRIPE_SECRET_PARAM=/dtl-global-platform/stripe/secret
# STRIPE_CONNECT_CLIENT_ID_PARAM=/dtl-global-platform/stripe/connect_client_id
# ANTHROPIC_API_KEY_PARAM=/dtl-global-platform/anthropic/api_key
# SES_FROM_EMAIL=onboarding@dtl-global.org